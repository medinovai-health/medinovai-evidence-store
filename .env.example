# Copy to .env for local development (never commit .env)
MOS_SERVICE_NAME=medinovai-evidence-store
MOS_TENANT_ID=dev-tenant
MOS_TEMPORAL_ADDRESS=127.0.0.1:7233
MOS_TEMPORAL_NAMESPACE=default
MOS_TASK_QUEUE=evidence-store-tasks
MOS_API_HOST=0.0.0.0
MOS_API_PORT=8000
MOS_FDA_CONFIG_PATH=config/fda-compliance.yaml
# Production: inject via secrets manager — not literal secrets here
MOS_REQUIRE_TENANT_HEADER=false
# Set true locally if API runs without Temporal (workflows will not start)
MOS_SKIP_TEMPORAL=false
# Async PostgreSQL (evidence store schema)
MOS_DATABASE_URL=postgresql+asyncpg://evidence:evidence@127.0.0.1:5433/evidence
# Set true for health-only tests without a database
MOS_SKIP_DB=false
